<!--Descriptive page name, messages and instructions-->
<h2 class="heading"><%= t(".page_heading") %></h2>

<%= error_messages_for :work %>
<!--/descriptions-->

<% if logged_in_as_admin? %>
  <!--main content-->
  <%= render "admin_edit_form" %>
  <!--/content-->
<% else %>
  <!--subnav-->
  <ul class="navigation actions" role="menu">
    <li><%= link_to t(".add_chapter"), new_work_chapter_path(@work) %></li>
    <% if @chapters %>
      <li><%= t(".edit_chapter") %>
        <% for chapter in @chapters %>
          <% if chapter.posted? %>
            <%= link_to h(chapter.position), edit_work_chapter_path(@work, chapter) %>
          <% else %>
            <%= link_to h(chapter.position) + t(".draft_label"), edit_work_chapter_path(@work, chapter) %>
          <% end %>
        <% end %></li>
      <li><%= link_to t(".manage_chapters"), manage_work_chapters_path(@work) %></li>
    <% end %>
    <% unless (@work.pseuds - current_user.pseuds).empty? %>
      <li><%= button_to t(".remove_me_as_co_creator"),
                remove_user_creatorship_work_path(@work),
                data: { confirm: "This will remove you from all chapters as well. Are you sure?" },
                method: :patch %></li>
    <% end %>
    <% if @work.posted? %>
      <li><%= link_to t(".orphan_work"), { controller: "orphans", action: "new", work_id: @work.id } %></li>
    <% end %>
    <li><%= link_to t(".delete_work"), confirm_delete_work_path(@work), data: { confirm: t(".delete_confirm") } %></li>
  </ul>
  <!--/subnav-->

  <!--main content-->
  <%= render partial: "standard_form" %>
  <!--/content-->
<% end %>
