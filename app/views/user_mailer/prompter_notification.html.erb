<% content_for :message do %>
  
  <p><%= t("mailer.general.greeting.informal.addressed_html", name: style_bold(@user.login)) %></p>

  <p>
    <% if @collection %>
      <%= t(".a_response_to_your_prompt.collection.html",
            collection_link: style_link(@collection.title, collection_url(@collection))) %>
    <% else %>
      <%= t(".a_response_to_your_prompt.no_collection") %>
    <% end %>
  </p>

  <p>
    <% url = @collection ? collection_work_url(@collection, @work) : work_url(@work) %>
    <%= creation_link_with_word_count(@work, url) %>
    <br>
    <%= creation_attribution_links(@work) %>
  </p>

  <%= render "work_info", work: @work %>

  <% if @collection && @collection.gift_notification.present? %>
    <p><%= @collection.gift_notification %></p>
  <% end %>
<% end %>
