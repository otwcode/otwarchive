<!--Descriptive page name, messages and instructions-->
<h2 class="heading"><%= t(".page_heading") %></h2>
<!--/descriptions-->

<!--subnav-->
<p class="navigation actions" role="navigation">
  <% if policy(LocaleLanguage).new? %>
    <%= link_to t(".navigation.add"), new_locale_language_path %>
  <% else %>
    <%= link_to t(".navigation.suggest"), new_feedback_report_path %>
  <% end %>
</p>
<!--/subnav-->

<!--main content-->
<% default_locale_language = LocaleLanguage.default %>
<dl class="language index group">
  <% @locale_languages.each do |locale_language| %>
    <dt><span lang="<%= locale_language.short %>"><%= locale_language.name %></span></dt>
    <dd>
      <% if locale_language != default_locale_language && policy(LocaleLanguage).edit? %>
        <p class="actions">
          <%= link_to t(".navigation.edit"), edit_locale_language_path(locale_language) %>
        </p>
      <% end %>
    </dd>
  <% end %>
</dl>
<!--main content-->
